# Go build caches (scripts set GOCACHE inside the repo)
.gocache/
.gocache-race/

# Compiled binaries (regenerated by `go build` / run_canonical.sh)
# NOT tracked: they are platform-specific (a Mac build cannot run on Linux/HPC).
# Each machine must build its own with: go build -o bin/download-sim .
bin/
Download_Problem
complexity-report
download-bench
benchmarks/results/**/download-bench
benchmarks/results/10_drip_grid_multiseed/tasks

# Presentation render artifacts (the .pptx is kept; intermediates are not)
presentation/*.pdf
presentation/slide-*.jpg

# OS / editor / agent local state
.DS_Store
.cursor/
.claude/settings.local.json

# NOTE: benchmark results (CSV + graphs + logs) ARE tracked on purpose so the
# experimental record lives with the code. Only the regenerable binary above
# is excluded from benchmarks/results/.

# Go toolchain tarballs (downloaded per-machine, never commit)
*.tar.gz
*.tar.gz.*
